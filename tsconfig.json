{
  "compilerOptions": {
    "rootDir": "test/",
    // Language and Environment
    "types": ["node"],
    "lib": ["ESNext", "DOM"],
    "erasableSyntaxOnly": true,
    "verbatimModuleSyntax": true,
    // Modules
    "moduleResolution": "nodenext",
    "module": "NodeNext",
    // Emit
    "outDir": "test-typescript",
    "sourceMap": true,
    // Interop constraints
    "forceConsistentCasingInFileNames": true
  },
  "include": ["test/**/*"]
}
